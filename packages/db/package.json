{
  "name": "@repo/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- prisma db seed",
    "onboard": "dotenv -e ../../.env -- node prisma/onboard-channels.mjs",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0"
  }
}
