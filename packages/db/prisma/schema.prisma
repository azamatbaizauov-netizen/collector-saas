generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// env читается из корневого .env через dotenv-cli в скриптах
// либо через DATABASE_URL в окружении при запуске

// ---------------------------------------------------------------------------
// Organization — клиент сервиса (один портал Битрикс24)
// ---------------------------------------------------------------------------

model Organization {
  id             String  @id @default(cuid())
  name           String
  bitrixPortalId String  @unique
  bitrixWebhook  String // B24_INCOMING_WEBHOOK; в Фазе 2 заменится на OAuth-токены
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings            OrganizationSettings?
  bitrixUsers         BitrixUser[]
  managers            Manager[]
  managerSheetAliases ManagerSheetAlias[]
  customerRatings     CustomerRating[]
  creditLimits        CreditLimit[]
  reminders           Reminder[]
  promises            Promise[]
  whatsappChannels    WhatsAppChannel[]
  scheduleJobs        ScheduleJob[]
  auditLogs           AuditLog[]
  aiActions           AiAction[]
  webhookProcessed    WebhookProcessed[]
  debtSheetState      DebtSheetState?
  whatsappTouches     WhatsAppTouch[]
}

// ---------------------------------------------------------------------------
// OrganizationSettings — конфигурация бизнес-правил на организацию
// Все пороги, тоны, шаблоны, расписания — здесь, не в коде
// ---------------------------------------------------------------------------

model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Пороги для рейтингов (см. CLAUDE.md → Рейтинг клиента)
  ratingRules       Json
  // Правила изменения кредитного лимита
  limitRules        Json
  // Тоны напоминаний по дням просрочки (0-3 / 4-10 / 11-30 / 30+)
  reminderTones     Json
  // Расписания воркеров: cron-выражения
  scheduleConfig    Json
  // Ссылки на промпт-файлы по сценарию
  templateConfig    Json
  // Максимум исходящих сообщений в минуту на канал WhatsApp
  whatsappRateLimit Int  @default(30)

  // Telegram: общий чат [собственник + МОПы] и личка собственника (ADR 0004)
  telegramGroupChatId String?
  ownerTelegramUserId String?

  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// BitrixUser — пользователи Битрикса с ролями в нашей системе
// ---------------------------------------------------------------------------

model BitrixUser {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  bitrixUserId   String
  role           BitrixUserRole
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())

  @@unique([organizationId, bitrixUserId])
  @@index([organizationId])
}

enum BitrixUserRole {
  OWNER // Собственник: получает Telegram-сводки, подтверждает лимиты
  FIN_MANAGER // Финансовый менеджер: ведёт дебиторку, получает эскалации
  SALES_MANAGER // Менеджер по продажам: ведёт переписку с клиентами
}

// ---------------------------------------------------------------------------
// Manager — менеджер (МОП) как личность. Связывает идентичности из
// Google Sheet / Telegram / WhatsApp / Битрикса. См. ADR 0005.
// Отдельно от BitrixUser: на пилоте у МОПа может не быть аккаунта в Битриксе.
// ---------------------------------------------------------------------------

model Manager {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  fullName         String // канон. имя, как мы его знаем
  telegramUserId   String? // узнаём при первом /start боту; null пока не привязан
  telegramUsername String? // @handle для адресных задач (механика 1, ADR 0004)
  bitrixUserId     String? // опц. связь с BitrixUser, если аккаунт есть
  isOwner          Boolean      @default(false) // владелец: его клиенты не идут в счётчик задач менеджерам, по ним MORNING_DIGEST в личку (ADR 0005)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  sheetAliases     ManagerSheetAlias[]
  whatsappChannels WhatsAppChannel[]

  @@unique([organizationId, telegramUserId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// ManagerSheetAlias — как имя менеджера пишут в колонке "МОП" Google Sheet.
// Free-text с вариантами: один менеджер = несколько псевдонимов.
// Приставка "Медет" (= собственник) относится к менеджеру из первого слова:
// "адилбек медет" → Адилбек. См. ADR 0005.
// ---------------------------------------------------------------------------

model ManagerSheetAlias {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  managerId       String
  manager         Manager      @relation(fields: [managerId], references: [id])
  alias           String // исходный текст ячейки: "Амир Медет"
  normalizedAlias String // lower+trim для матчинга: "амир медет"
  createdAt       DateTime     @default(now())

  @@unique([organizationId, normalizedAlias]) // один псевдоним → один менеджер
  @@index([managerId])
}

// ---------------------------------------------------------------------------
// CustomerRating — рейтинг клиента + полная история изменений
// Каждая запись = один факт изменения рейтинга
// ---------------------------------------------------------------------------

model CustomerRating {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  contactId      String // Битрикс contact ID
  rating         CustomerRatingValue
  previousRating CustomerRatingValue?
  changedBy      String // 'system' или bitrixUserId
  overrideReason String? // Обязательно если changedBy != 'system'
  changedAt      DateTime             @default(now())

  @@index([organizationId, contactId])
  @@index([organizationId, changedAt])
}

enum CustomerRatingValue {
  RELIABLE // Надёжный: 0 просрочек за 6 мес, ≥5 оплат
  NORMAL // Нормальный: 1-2 просрочки ≤7 дней
  RISK // Риск: 3+ просрочки или одна >14 дней
  DANGEROUS // Опасный: просрочка >30 дней или 2+ невыполненных обещания
  STOP // STOP: просрочка >60 дней или долг > лимит × 2
}

// ---------------------------------------------------------------------------
// CreditLimit — кредитный лимит + история изменений
// Изменения применяются только после подтверждения (status APPROVED)
// ---------------------------------------------------------------------------

model CreditLimit {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  contactId      String
  // Суммы в минорных единицах (тиыны). Никогда не float.
  limitAmount    BigInt
  previousAmount BigInt?
  currency       String            @default("USD")
  status         CreditLimitStatus @default(PENDING)
  changedBy      String // 'system' или bitrixUserId
  approvedBy     String? // bitrixUserId подтвердившего
  approvedAt     DateTime?
  changedAt      DateTime          @default(now())

  @@index([organizationId, contactId])
  @@index([organizationId, status])
}

enum CreditLimitStatus {
  PENDING // Ожидает подтверждения собственником
  APPROVED // Подтверждено
  REJECTED // Отклонено
}

// ---------------------------------------------------------------------------
// Reminder — каждое касание по дебиторке (авто или менеджером)
// ---------------------------------------------------------------------------

model Reminder {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id])
  contactId         String // Битрикс contact ID
  dealId            String? // Битрикс deal ID
  channel           ReminderChannel
  source            ReminderSource // Кто инициировал: система или менеджер
  tone              ReminderTone
  templateKey       String? // Ключ промпта (только для source=AUTO)
  messageText       String
  greenApiMessageId String? // ID в Green API для дедупликации
  status            ReminderStatus  @default(PENDING)
  sentAt            DateTime?
  clientReply       String?
  replyReceivedAt   DateTime?
  intent            ReplyIntent? // Результат парсинга ответа клиентом
  aiActionId        String?
  aiAction          AiAction?       @relation(fields: [aiActionId], references: [id])
  createdAt         DateTime        @default(now())

  promise Promise?

  @@index([organizationId, contactId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

enum ReminderChannel {
  WHATSAPP
}

enum ReminderSource {
  AUTO // Воркер инициировал и отправил
  MANAGER // Менеджер написал сам, система зафиксировала из Green API webhook
}

enum ReminderTone {
  SOFT // 0-3 дня просрочки
  FIRM // 4-10 дней
  STRICT // 11-30 дней
  FINAL // 30+ дней
}

enum ReminderStatus {
  PENDING // В очереди на отправку
  SENT // Отправлено через Green API
  DELIVERED // Доставлено (если Green API подтвердил)
  FAILED // Ошибка отправки
  REPLIED // Получен ответ от клиента
}

enum ReplyIntent {
  PROMISE_TO_PAY // «переведу в среду», «оплачу завтра»
  PAID // «уже перевёл», «оплатил вчера»
  DISPUTE // «не согласен с суммой», «у меня другие данные»
  REQUEST_DELAY // «можно ещё неделю», «дайте отсрочку»
  OTHER // Ответ не по теме или неразборчиво
}

// ---------------------------------------------------------------------------
// Promise — обещание оплаты, извлечённое из ответа клиента
// ---------------------------------------------------------------------------

model Promise {
  id               String        @id @default(cuid())
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id])
  contactId        String
  reminderId       String        @unique
  reminder         Reminder      @relation(fields: [reminderId], references: [id])
  // Сумма в минорных единицах. Может быть null если клиент не назвал сумму.
  amount           BigInt?
  currency         String        @default("USD")
  // Окно обещанной оплаты. Для точной даты ("завтра", "в среду") from == to.
  // Для диапазона ("через 1-2 дня", "4-5 числа") from < to. См. ADR 0002.
  promisedDateFrom DateTime
  promisedDateTo   DateTime
  status           PromiseStatus @default(PENDING)
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())

  @@index([organizationId, contactId])
  @@index([organizationId, promisedDateTo])
  @@index([organizationId, status])
}

enum PromiseStatus {
  PENDING // Ждём даты оплаты
  FULFILLED // Оплата поступила
  BROKEN // Дата прошла, оплаты нет
  CANCELLED // Отменено вручную
}

// ---------------------------------------------------------------------------
// AiAction — лог каждого вызова Claude API
// Основа для тарификации в Фазе 2
// ---------------------------------------------------------------------------

model AiAction {
  id               String        @id @default(cuid())
  // nullable: системные вызовы не привязаны к организации
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  scenario         String // 'generate-reminder' | 'parse-reply' | 'explain-trend'
  promptVersion    String // 'v1', 'v2' — версия файла из packages/ai/prompts/
  model            String // 'claude-haiku-4-5-20251001' | 'claude-sonnet-4-6'
  inputSummary     String // Краткое описание входных данных (не полный промпт)
  outputSummary    String?
  inputTokens      Int
  outputTokens     Int
  latencyMs        Int
  // Стоимость в микродолларах (×1_000_000 от USD) — точность без float
  costMicrodollars Int
  success          Boolean
  errorMessage     String?
  createdAt        DateTime      @default(now())

  reminders Reminder[]

  @@index([organizationId, scenario])
  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// WhatsAppChannel — подключённые номера менеджеров через Green API
// Каждый менеджер = отдельный экземпляр (instance) в Green API
// ---------------------------------------------------------------------------

model WhatsAppChannel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  instanceId     String // ID инстанса в Green API
  instanceToken  String // Токен инстанса в Green API
  phone          String // Номер телефона менеджера
  managerId      String? // FK на Manager (заменяет managerName + bitrixUserId)
  manager        Manager?     @relation(fields: [managerId], references: [id])
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, instanceId])
  @@index([organizationId])
  @@index([managerId])
}

// ---------------------------------------------------------------------------
// WhatsAppTouch — факт касания менеджера в WhatsApp (из Green API webhook).
// Лёгкая запись для счётчика покрытия на cutoff: НЕ дублирует Битрикс, матчинг
// с дебиторкой по номеру телефона (phone E.164), а не по contactId. См. ADR 0006.
// ---------------------------------------------------------------------------

model WhatsAppTouch {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id])
  managerId         String? // из WhatsAppChannel по instanceId; null — канал без менеджера
  phone             String // E.164 контрагента (+7…/+996…), ключ матчинга с планом дня
  direction         TouchDirection
  greenApiMessageId String // дедуп касаний
  touchedAt         DateTime // время сообщения из вебхука

  createdAt DateTime @default(now())

  @@unique([organizationId, greenApiMessageId])
  @@index([organizationId, touchedAt])
  @@index([organizationId, managerId, touchedAt])
}

enum TouchDirection {
  INCOMING // сообщение от клиента
  OUTGOING // менеджер написал сам (= «связался», идёт в счётчик покрытия)
}

// ---------------------------------------------------------------------------
// ScheduleJob — расписания воркеров на организацию
// ---------------------------------------------------------------------------

model ScheduleJob {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  jobType        ScheduleJobType
  cronExpression String
  isActive       Boolean         @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  lastStatus     String? // 'success' | 'failed' | сообщение об ошибке
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, jobType])
}

enum ScheduleJobType {
  DAILY_OVERDUE_CHECK // 14:00 напоминание-счётчик: кто ещё не написал должникам (ADR 0006)
  RATING_RECALC // Пересчёт рейтингов клиентов
  MORNING_DIGEST // Ежедневная сводка собственнику в личку: его клиенты "Медет" (ADR 0004/0005)
  PROMISE_FOLLOWUP // Проверка выполнения обещаний оплаты
  DEBT_SHEET_POLL // Опрос Google Sheet дебиторки: при смене version — импорт (ADR 0003)
  DAILY_PLAN // 09:30 план дня менеджерам в общий Telegram-чат по @username (ADR 0004, механика 1)
  FINAL_COVERAGE // 17:00 финальный счётчик: кто так и не вышел на связь сегодня (ADR 0006)
}

// ---------------------------------------------------------------------------
// AuditLog — лог значимых действий для разборок
// ---------------------------------------------------------------------------

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  actor          String // 'system' или bitrixUserId
  action         String // 'rating.changed' | 'limit.approved' | 'promise.broken'
  entityType     String // 'CustomerRating' | 'CreditLimit' | 'Promise'
  entityId       String
  before         Json?
  after          Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
}

// ---------------------------------------------------------------------------
// WebhookProcessed — дедупликация входящих webhook'ов
// Один event_id обрабатывается ровно один раз
// ---------------------------------------------------------------------------

model WebhookProcessed {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  source         WebhookSource
  eventId        String
  processedAt    DateTime      @default(now())

  @@unique([source, eventId])
  @@index([organizationId])
}

enum WebhookSource {
  BITRIX
  WHATSAPP
}

// ---------------------------------------------------------------------------
// DebtSheetState — курсор опроса Google Sheet дебиторки (ADR 0003)
// Храним последнюю обработанную version Drive, чтобы не переимпортировать
// неизменившийся файл. Это технический буфер, НЕ копия дебиторки.
// ---------------------------------------------------------------------------

model DebtSheetState {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  lastVersion      String? // Drive files.get version последнего успешного импорта
  lastModifiedTime String? // modifiedTime того же импорта (для логов)
  lastPolledAt     DateTime? // когда последний раз опрашивали Drive
  lastImportedAt   DateTime? // когда последний раз реально импортировали (version сменилась)

  // Счётчики последнего импорта — для сводки и диагностики «съехавшей» таблицы
  lastImported        Int @default(0)
  lastSkipped         Int @default(0)
  lastUnmatched       Int @default(0)
  lastBrokenPhone     Int @default(0)
  lastCurrencySuspect Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
