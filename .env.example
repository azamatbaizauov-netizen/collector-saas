# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/saas_opt?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Битрикс24 (Локальное приложение, пилот)
B24_INCOMING_WEBHOOK="https://ваш-портал.bitrix24.kz/rest/1/токен/"
B24_PORTAL_ID="ваш-портал.bitrix24.kz"

# Wazzup
WAZZUP_API_KEY="ваш-api-ключ"
WAZZUP_WEBHOOK_SECRET="секрет-для-верификации-вебхуков"

# Anthropic (Claude API)
ANTHROPIC_API_KEY="sk-ant-..."

# Telegram (бот собственника)
TELEGRAM_BOT_TOKEN="токен-от-BotFather"

# Приложение
NODE_ENV="development"
API_PORT="3000"
API_HOST="0.0.0.0"
PUBLIC_URL="https://ваш-домен.com"

# Организация пилотного клиента (заполняется после первой миграции)
PILOT_ORGANIZATION_ID=""
