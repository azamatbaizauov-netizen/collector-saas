# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/saas_opt?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Битрикс24 (Локальное приложение, пилот)
B24_INCOMING_WEBHOOK="https://ваш-портал.bitrix24.kz/rest/1/токен/"
B24_PORTAL_ID="ваш-портал.bitrix24.kz"

# Green API (WhatsApp-шлюз)
# Партнёрский токен — аккаунтный секрет для управления инстансами
GREEN_API_PARTNER_TOKEN="gac...."
GREEN_API_PARTNER_URL="https://api.greenapi.com"

# Anthropic (Claude API)
ANTHROPIC_API_KEY="sk-ant-..."

# Telegram (бот собственника)
TELEGRAM_BOT_TOKEN="токен-от-BotFather"

# Приложение
NODE_ENV="development"
API_PORT="3000"
API_HOST="0.0.0.0"
PUBLIC_URL="https://ваш-домен.com"

# Организация пилотного клиента
PILOT_ORGANIZATION_ID="pilot"
PILOT_ORGANIZATION_NAME="Пилотный клиент"

# Бутстрап первого WhatsApp-канала для seed-скрипта
# (instanceId и token берутся из кабинета Green API; после seed живут в БД)
SEED_WA_INSTANCE_ID=""
SEED_WA_INSTANCE_TOKEN=""
SEED_WA_PHONE=""
SEED_WA_MANAGER=""
