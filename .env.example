# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/saas_opt?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Битрикс24 (Локальное приложение, пилот)
B24_INCOMING_WEBHOOK="https://ваш-портал.bitrix24.kz/rest/1/токен/"
B24_PORTAL_ID="ваш-портал.bitrix24.kz"

# Green API (WhatsApp-шлюз)
# Партнёрский токен — аккаунтный секрет для управления инстансами
GREEN_API_PARTNER_TOKEN="gac...."
GREEN_API_PARTNER_URL="https://api.greenapi.com"
# Секрет webhookUrlToken: задаётся в setSettings Green API и проверяется на
# POST /webhook/whatsapp (Authorization: Bearer). Пусто — проверка выключена.
WHATSAPP_WEBHOOK_TOKEN=""

# Google Sheets / Drive (источник дебиторки, ADR 0003)
# JSON-ключ сервисного аккаунта (роль Viewer). СЕКРЕТ — путь вне репозитория, в git не коммитим.
GOOGLE_APPLICATION_CREDENTIALS="/абсолютный/путь/к/service-account.json"
# fileId таблицы «Дебиторка LR» (.xlsx) в Google Drive
DEBT_SHEET_FILE_ID=""

# Anthropic (Claude API)
ANTHROPIC_API_KEY="sk-ant-..."

# Telegram (бот собственника)
TELEGRAM_BOT_TOKEN="токен-от-BotFather"

# Приложение
NODE_ENV="development"
# api-сервер читает PORT/HOST (apps/api/src/index.ts). По умолчанию 3001.
PORT="3001"
HOST="0.0.0.0"
PUBLIC_URL="https://ваш-домен.com"

# Прод-развёртывание на VPS (docker-compose.prod.yml + Caddyfile)
# Пароль Postgres внутри compose-сети (в dev compose — saas_opt_dev)
POSTGRES_PASSWORD=""
# Домен, на который указывает DNS A-записью на IP VPS. Caddy берёт на него LE-сертификат.
API_DOMAIN="api.ваш-домен.com"
# E-mail для регистрации сертификата Let's Encrypt (уведомления об истечении)
ACME_EMAIL="you@example.com"

# Организация пилотного клиента
PILOT_ORGANIZATION_ID="pilot"
PILOT_ORGANIZATION_NAME="Пилотный клиент"

# Бутстрап первого WhatsApp-канала для seed-скрипта
# (instanceId и token берутся из кабинета Green API; после seed живут в БД)
SEED_WA_INSTANCE_ID=""
SEED_WA_INSTANCE_TOKEN=""
SEED_WA_PHONE=""
# Ключ менеджера из seed.mjs (adilbek|amir|halima|savutzhan|bibigul) для привязки номера
SEED_WA_MANAGER_KEY=""

# Массовый онбординг номеров (pnpm --filter @repo/db onboard). Список каналов —
# JSON-файл ВНЕ репозитория (токены секретны): [{managerKey,instanceId,instanceToken,phone}]
WA_CHANNELS_FILE="/абсолютный/путь/к/wa-channels.json"
# WA_SET_WEBHOOK=1 — скрипт сам проставит webhookUrl каждому инстансу в Green API
WA_SET_WEBHOOK=""
# Адрес вебхука (если не задан — соберётся как https://${API_DOMAIN}/webhook/whatsapp)
WHATSAPP_WEBHOOK_URL=""
